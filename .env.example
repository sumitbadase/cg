# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# JIRA
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token

# GitHub
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_ORG=your-github-org

# Graph database (Gremlin-compatible)
GRAPH_DB_URL=ws://localhost:8182/gremlin
GRAPH_DB_USERNAME=
GRAPH_DB_PASSWORD=

# Scheduler
SCHEDULER_ENABLED=false
SCHEDULER_CRON=*/15 * * * *
